# URL del Backend bajo prefijo /api para evitar conflicto con rutas SPA
VITE_API_BASE_URL=https://serveriot.francecentral.cloudapp.azure.com/api

# Ruta del endpoint de login
VITE_AUTH_LOGIN_PATH=/auth/login

# MQTT por WebSocket (apuntando al proxy de Nginx)
VITE_MQTT_URL=wss://serveriot.francecentral.cloudapp.azure.com/mqtt

# Topics MQTT de lecturas
VITE_MQTT_TEMP_TOPIC=devices/GONZALO/temperatura
VITE_MQTT_HUM_TOPIC=devices/GONZALO/humedad

# Credenciales MQTT
VITE_MQTT_USERNAME=datosiot
VITE_MQTT_PASSWORD=datosiot@2026